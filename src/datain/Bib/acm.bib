@inproceedings{10.1145/3495018.3501056,
author = {Lei, Wenli and Ren, Xincheng and Li, Bin and Liu, Zhouzhou},
title = {An improved Low Power Wide Area Network Node Location Algorithm for Forest Fire Monitoring System},
year = {2022},
