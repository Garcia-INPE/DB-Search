@inproceedings{10.1145/3666025.3699318,
author = {Fu, Xiao and Hu, Yue and Sutrave, Prashanth and Beerel, Peter A. and Raghavan, Barath},
title = {FireLoc: Low-latency Multi-modal Wildfire Geolocation},
year = {2024},
