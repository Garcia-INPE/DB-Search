author = {Chandra, Ritesh and Kumar, Shashi Shekhar and Patra, Rushil and Agarwal, Sonali},
title = {Decision support system for Forest fire management using Ontology with Big Data and LLMs},
year = {2025},
issue_date = {Aug 2025},
publisher = {Kluwer Academic Publishers},
address = {USA},
volume = {28},
number = {8},
issn = {1386-7857},
url = {https://doi.org/10.1007/s10586-025-05383-0},
doi = {10.1007/s10586-025-05383-0},
abstract = {Forests are crucial for ecological balance, but wildfires are a major cause of forest loss, posing significant risks. Fire weather indices, which assess wildfire risk and predict resource demands, are vital. With the rise of sensor networks in fields like healthcare and environmental monitoring, semantic sensor networks are increasingly used to gather climatic data such as wind speed, temperature, and humidity. However, processing these data streams to determine fire weather indices presents challenges, underscoring the growing importance of effective forest fire detection. This paper discusses using Apache Spark for early forest fire detection, enhancing fire risk prediction with meteorological and geographical data. Building on our previous development of Semantic Sensor Network (SSN) ontologies and Semantic Web Rules Language (SWRL) for managing forest fires in Monesterial Natural Park, we expanded SWRL to improve a Decision Support System (DSS) using a Large Language Models (LLMs) and Spark framework. We implemented real-time alerts with Spark streaming, tailored to various fire scenarios, and validated our approach using ontology metrics, query-based evaluations, LLMs score precision, F1 score, and recall measures.},
journal = {Cluster Computing},
month = aug,
numpages = {21},
keywords = {LLMs, Spark, SSN, DSS, Forest Fire}
}

