@inproceedings{10.5555/1162708.1162756,
author = {Hu, Xiaolin and Muzy, Alexandre and Ntaimo, Lewis},
title = {A hybrid agent-cellular space modeling approach for fire spread and suppression simulation},
year = {2005},
isbn = {0780395190},
publisher = {Winter Simulation Conference},
abstract = {This paper presents a first effort to integrate DEVS-based cellular space models with agent models using dynamic structure DEVS for the simulation of forest fire spread and suppression. The main focus is on the interaction between mobile agents (such as fire fighters, air-tankers) and forest cells. DEVS models' dynamic structure modeling capability is applied where couplings between mobile agents and forest cells are dynamically added and removed when the agents move in the cellular space. Two methods, a time-based method and an event-based method, are discussed to update a mobile agent's position in a cellular space. A system architecture is presented and a prototype fire spread and suppression example is implemented. Based on this initial work, we hope to understand more about the nature of this hybrid agent-cellular space approach and to apply it to the modeling and simulation of forest fires and other ecological applications.},
booktitle = {Proceedings of the 37th Conference on Winter Simulation},
pages = {248–255},
numpages = {8},
location = {Orlando, Florida},
series = {WSC '05}
}

@inproceedings{10.1145/3696500.3696555,
author = {Xi, Jian and Zong, Kai and Jing, Hongyu and Guan, Lei},
title = {Research on the Dynamic Safety Supervision Model of Chemical Enterprise Based on Machine Learning},
year = {2024},
isbn = {9798400710278},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3696500.3696555},
doi = {10.1145/3696500.3696555},
abstract = {This paper first analyzes the accident data in China's chemical industry from 2018 to 2022, revealing that although the number of accidents and the mortality rate have decreased, the accident rate remains high, highlighting the urgency of strengthening safety supervision methods. To address this, a dynamic supervision indicator system covering multiple key dimensions such as production load, alarm conditions, operation quantity, and maintenance status has been constructed. This indicator system can capture key factors related to safety risks through multidimensional monitoring of enterprises' daily work safety status. The study uses the entropy weight method to objectively weight each indicator and employs K-means and DBSCAN clustering algorithms to classify enterprise data. While the entropy weight method provides an intuitional basis for feature weighting, further optimization is needed to improve sample discrimination. The K-means algorithm effectively distinguishes different risk states of enterprises, such as shutdown and full-load production, and reasonably classifies enterprises into three categories: special control, key attention, and general supervision. In contrast, the DBSCAN algorithm performs better in identifying high-risk enterprises but is limited in finely distinguishing between special control and key attention enterprises. The final results show that the K-means algorithm performs best when combined with the indicator system for dynamic supervision, particularly in accurately identifying low-risk and generally supervised enterprises. By establishing a comprehensive dynamic supervision indicator system and applying machine learning algorithms, this paper provides a new technological path for safety supervision of hazardous chemical enterprises, demonstrating the potential of intelligent supervision in enhancing accident prevention and risk control levels.},
booktitle = {Proceedings of the 2024 International Conference on Big Data and Digital Management},
pages = {323–330},
numpages = {8},
location = {Shanghai, China},
series = {ICBDDM '24}
}

@inproceedings{10.1007/978-3-031-93718-7_23,
author = {Zhang, Yakai and Huang, Yanrong and Wang, Chunhui and Chen, Shanguang and Li, Zhizhong},
title = {General Design Principles of Human-Machine Teaming: A Narrative Review},
year = {2025},
isbn = {978-3-031-93717-0},
publisher = {Springer-Verlag},
address = {Berlin, Heidelberg},
url = {https://doi.org/10.1007/978-3-031-93718-7_23},
doi = {10.1007/978-3-031-93718-7_23},
abstract = {With the rapid development of automation and intelligent systems, human-machine teaming (HMT) is becoming increasingly important in various fields. With a large body of research focusing on this topic for different application domains, there is a need to summarize general design principles for HMT. This review serves for this need. Through a systematic review, we identify the scope of the narrative review, and then through the narrative review methodology, we summarize various design guidelines from HCI, Human-Robot Interaction (HRI), and specific HMT scenarios. As a result, this paper presents general principles for HMT design, as well as exploring how to define the HMT process, how to design effective prompting and alerting mechanisms, and what collaborative approaches are available. These results provide a theoretical foundation and practical guidance for the development of future HMT systems.},
booktitle = {Engineering Psychology and Cognitive Ergonomics: 22nd International Conference, EPCE 2025, Held as Part of the 27th HCI International Conference, HCII 2025, Gothenburg, Sweden, June 22–27, 2025, Proceedings, Part I },
pages = {355–367},
numpages = {13},
keywords = {Human-Machine Teaming, Design Principles, Collaboration},
location = {Gothenburg, Sweden}
}

