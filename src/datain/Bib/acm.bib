author = {Fujimura, Kikuo and Kochenderfer, Mykel and Wray, Kyle},
title = {Introduction to the Special Issue on Cooperative Decision Making},
year = {2024},
issue_date = {June 2025},
publisher = {Association for Computing Machinery},
