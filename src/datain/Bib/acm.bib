@inproceedings{10.1007/978-3-032-02049-9_7,
author = {Chandra, Ritesh and Agarwal, Sonali and Tiwari, Sadhana},
title = {Ontology-Based Forest Fire Management Using Complex Event Processing and&nbsp;Large Language Models},
year = {2025},
