@inproceedings{10.1145/3697467.3697582,
author = {Kong, Fanteng and Zhu, Ning and Zhu, Wenjun and Xu, Hengpeng and Wang, Jun},
title = {Research on Fire Risk Prediction Method Based on Multi-Source Data Perception},
