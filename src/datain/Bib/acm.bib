@inproceedings{10.5555/3522802.3522906,
author = {Onggo, Bhakti Stephan and Currie, Christine and Perdana, Tomy and Fauzi, Gheo Rahmat and Achmad, Audi Luqmanul Hakim and Endyana, Cipta},
title = {Relief food supply network simulation},
year = {2022},
publisher = {IEEE Press},
abstract = {Research into simulation modelling to support disaster management has focused on large disasters. In some regions, there are frequent small-to-medium scale disasters, which require daily decisions to be made. These are typically described as routine emergencies. For example, in Indonesia's West Java province, on average, there were 4.6 disasters per day between 2016 and 2020. This paper presents a simulation model of relief food distribution to refugees in a region that is vulnerable to multiple disasters on a daily basis. To illustrate how the model can support disaster management decision making, we use the West Java case. The model demonstrates that the current warehouse locations and routing heuristic can cope with the demand; however, improvements are needed to cope with an expected increase in the demand due to an increased number of disasters as a result of climate change and a growing population.},
booktitle = {Proceedings of the Winter Simulation Conference},
articleno = {133},
numpages = {12},
location = {Phoenix, Arizona},
series = {WSC '21}
}

