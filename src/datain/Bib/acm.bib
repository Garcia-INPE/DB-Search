@inproceedings{10.1145/3696673.3723082,
author = {Imbesi, Tony and Hu, Xiaolin and Xin, Ming and Chao, Haiyang},
title = {FireCrowdSensing: A Map-Based Web Application for Crowdsensing of Prescribed Fires},
year = {2025},
