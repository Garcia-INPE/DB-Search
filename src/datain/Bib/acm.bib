title = {Human-caused Forest Fires Statistical Analysis Research},
year = {2025},
isbn = {9798400718007},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3716895.3717025},
doi = {10.1145/3716895.3717025},
abstract = {Forest fires is a class of natural disasters that are sudden, destructive, hazardous and difficult to deal with and fight, posing a great threat to the ecological environment and the safety of human life and property. Man-made forest fires account for nearly nine-tenths of the disasters that have occurred, and man-made fires have become the main cause of forest fires. Due to the complexity of analysis, difficulty of disposal, and variability of traceability of anthropogenic forest fires, the research on anthropogenic forest fires is still in the initial stage, and has not yet formed a systematic system of application methods. This paper is based on typical regional fire characteristics, analyzing the research difficulties of anthropogenic fire, and carrying out systematic analysis and research from the aspects of prediction and early warning of anthropogenic fire and risk assessment through keyword extraction and semantic analysis methods.},
