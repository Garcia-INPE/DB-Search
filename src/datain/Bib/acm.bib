doi = {10.1145/3744736.3749190},
abstract = {Wildfire seasons are becoming longer and more destructive, increasing the risk of loss of lives and property damage around the world. As such, knowing how to prepare and evacuate safely is critically important, yet may be daunting for those who have never experienced a wildfire before. In this interactivity paper, we present the initial design of a virtual reality game that addresses how and what to pack in preparation for evacuating a house. The training simulation includes a tutorial phase, a timed ‘play’ phase where players pack items from around the house, and an ending scene with a list of the items packed. We also include initial results and design feedback from a small pilot study. These findings further support the use and development of virtual reality for natural hazard training applications.},
