@inproceedings{10.1145/3590837.3590916,
author = {Chap, Weing Kham and Rao, Anindita Chatterjee and Pandey, Praveen Kumar},
title = {A Technological Review on Rise of Esports in World Economy},
year = {2023},
isbn = {9781450399937},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3590837.3590916},
doi = {10.1145/3590837.3590916},
abstract = {Over the past few years, Esports has evolved from a niche activity that was confined to LAN gatherings in basements to a mainstream form of competitive computer/mobile gaming that has become a major player in the digital youth culture. It has gained credibility and respect in the gaming industry and has also made its way into emerging markets. With prize pools reaching seven to eight digits, Esports has now become equally as lucrative as traditional sports. Despite the rapid growth of the video gaming industry, the influence of Esports has often been underestimated, despite its popularity among gamers and the rise of internet usage.This paper examines the role of Esports in the world as a contemporary sport and business option. It offers a brief history of Esports, the key drivers behind its growth, and its profound impact on the culture and policies of some nations. The analysis also explores the unhinged market of Esports among the youth and the implications of its rising popularity in the gaming industry. In conclusion, Esports has emerged as a powerful force in the gaming world, with a significant impact on the global youth culture. It offers an exciting and engaging form of entertainment for millions of people worldwide, and its continued growth is expected to bring significant opportunities for businesses, sponsors, and stakeholders in the gaming industry. As such, Esports deserves more recognition as a legitimate and relevant sport that has significant economic and social implications in the world today.},
booktitle = {Proceedings of the 4th International Conference on Information Management &amp; Machine Intelligence},
articleno = {79},
numpages = {8},
location = {Jaipur, India},
series = {ICIMMI '22}
}

@inproceedings{10.1145/3415958.3433039,
author = {Peinl, Peter},
title = {A Retrospective on ASPires: An Advanced System for the Prevention and Early Detection of Forest Fires},
year = {2020},
isbn = {9781450381154},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
