@article{10.5555/2851291.2851297,
author = {Kalabokidis, Kostas and Athanasis, Nikolaos and Vasilakos, Christos and Palaiologou, Palaiologos},
title = {Porting of a wildfire risk and fire spread application into a cloud computing environment},
year = {2014},
issue_date = {March 2014},
publisher = {Taylor &amp; Francis, Inc.},
address = {USA},
volume = {28},
number = {3},
issn = {1365-8816},
abstract = {Effective wildfire management is an essential part of forest firefighting strategies to minimize damage to land resources and loss of human lives. Wildfire management tools often require a large number of computing resources at a specific time. Such computing resources are not affordable to local fire agencies because of the extreme upfront costs on hardware and software. The emerging cloud computing technology can be a cost-and result-effective alternative. The purpose of this paper is to present the development and the implementation of a state-of-the-art application running in cloud computing, composed of a wildfire risk and a wildfire spread simulation service. The two above applications are delivered within a web-based interactive platform to the fire management agencies as Software as a Service SaaS. The wildfire risk service calculates and provides daily to the end-user maps of the hourly forecasted fire risk for the next 112 hours in high spatiotemporal resolution, based on forecasted meteorological data. In addition, actual fire risk is calculated hourly, based on meteorological conditions provided by remote automatic weather stations. Regarding the wildfire behavior simulation service, end users can simulate the fire spread by simply providing the ignition point and the projected duration of the fire, based on the HFire algorithm. The efficiency of the proposed solution is based on the flexibility to scale up or down the number of computing nodes needed for the requested processing. In this context, end users will be charged only for their consumed processing time and only during the actual wildfire confrontation period. The system utilizes both commercial and open source cloud resources. The current prototype is applied in the study area of Lesvos Island, Greece, but its flexibility enables expansion in different geographical areas.},
journal = {Int. J. Geogr. Inf. Sci.},
month = mar,
pages = {541–552},
numpages = {12},
keywords = {cloud computing, fire behavior, forest fires, parallel processing, risk assessment}
}

@inproceedings{10.1145/3180374.3180380,
author = {Lin, Menglong and Yao, Yiping},
title = {Simulation of water pollution accident based on cellular automata},
year = {2018},
isbn = {9781450354318},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3180374.3180380},
doi = {10.1145/3180374.3180380},
abstract = {The frequent occurrence of water pollution accidents has caused great damage to the ecological environment. Due to the complexity and uncertainty of the basin ecosystem, the traditional mathematical analysis method is not effective in predicting the diffusion of pollutants and can not meet the requirement of real-time. Cellular automata is an effective method to model the complex systems. A 2D model based on cellular automata is presented in this paper to predict the diffusion of the water pollutants. Firstly, the area is divided into cell spaces, and the pollutant diffusion rules are established by considering the influencing factors including pollutant concentration, wind and water current and land area. Finally, the model is applied to simulate the diffusion of the pollutants after a water pollution accident. The simulation results show that the model can simulate the diffusion of the pollutants effectively.},
booktitle = {Proceedings of the 2018 2nd International Conference on Management Engineering, Software Engineering and Service Sciences},
pages = {270–274},
numpages = {5},
keywords = {Cellular automata, Diffusion, Simulation, Water pollution},
location = {Wuhan, China},
series = {ICMSS 2018}
}

@article{10.1016/j.envsoft.2009.03.013,
author = {Millington, James D. A. and Wainwright, John and Perry, George L. W. and Romero-Calcerrada, Raul and Malamud, Bruce D.},
title = {Modelling Mediterranean landscape succession-disturbance dynamics: A landscape fire-succession model},
year = {2009},
issue_date = {October, 2009},
publisher = {Elsevier Science Publishers B. V.},
address = {NLD},
volume = {24},
number = {10},
issn = {1364-8152},
url = {https://doi.org/10.1016/j.envsoft.2009.03.013},
doi = {10.1016/j.envsoft.2009.03.013},
abstract = {We present a spatially explicit Landscape Fire-Succession Model (LFSM) developed to represent Mediterranean Basin landscapes and capable of integrating modules and functions that explicitly represent human activity. Plant-functional types are used to represent spatial and temporal competition for resources (water and light) in a rule-based modelling framework. Vegetation dynamics are represented using a rule-based community-level modelling approach that considers multiple succession pathways and vegetation climax states. Wildfire behaviour is represented using a cellular-automata model of fire spread that accounts for land-cover flammability, slope, wind and vegetation moisture. Results show that wildfire spread parameters have the greatest influence on two aspects of the model: land-cover change and the wildfire regime. This sensitivity highlights the importance of accurately parameterising this type of grid-based model for representing landscape-level processes. We use a pattern-oriented modelling approach in conjunction with wildfire power-law frequency-area scaling exponent @b to calibrate the model. Parameters describing the role of soil moisture on vegetation dynamics are also found to significantly influence land-cover change. Recent improvements in understanding the role of soil moisture and wildfire fuel loads at the landscape-level will drive advances in Mediterranean LFSMs.},
journal = {Environ. Model. Softw.},
month = oct,
pages = {1196–1208},
numpages = {13},
keywords = {Landscape fire-succession model, Mediterranean landscape, Pattern-oriented modelling, Succession-disturbance dynamics, Wildfire regime}
}

