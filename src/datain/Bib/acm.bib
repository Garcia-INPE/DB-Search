address = {San Diego, CA, USA},
abstract = {DEVS-FIRE is a model for discrete event simulation of wildfire spread, where fire spread is modeled as a contagion process in a cellular space of forest cells. In this paper, DEVS-FIRE is validated using FARSITE, a widely used fire spread model. Both graphical and statistical approaches are used and the results show that the output of DEVS-FIRE is comparable to that of FARSITE under a wide range of input conditions.},
booktitle = {Proceedings of the 2008 Spring Simulation Multiconference},
pages = {355–361},
numpages = {7},
keywords = {DEVS-FIRE, cellular space model, validation, wildfire},
location = {Ottawa, Canada},
