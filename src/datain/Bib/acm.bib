author = {Battauz, Michela and Vidoni, Paolo},
title = {A likelihood-based boosting algorithm for factor analysis models with binary data},
year = {2022},
issue_date = {Apr 2022},
publisher = {Elsevier Science Publishers B. V.},
address = {NLD},
