@inproceedings{10.1145/3744736.3749192,
author = {Johns, M.J. and Hirsch, Linda and Lu, Yiyang and Ho, Bridget and Toledo, Anna and Lai, Tristyn and Dhandapani, Krithik and Melcer, Edward F. and Isbister, Katherine},
title = {A Playful Wildfire Simulation System in Two Minigames},
year = {2025},
isbn = {9798400720239},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3744736.3749192},
doi = {10.1145/3744736.3749192},
abstract = {During wildfires, the safety of whole communities can depend on individuals’ decisions about home hardening and neighborhood connections. However, awareness and understanding of one’s impact are often lacking. Few simulation tools address this gap, tending to instead focus on an expert audience. We designed an interactive wildfire simulation system for public engagement and incorporated it into two minigames: one with a top-down view of community-level impact and a second with a close-up perspective of neighboring houses with home-hardening details. We developed the system using a gameful approach to make the complex wildfire systems in the Wildland Urban Interface (WUI) more approachable and tested it in an early user study (N=5). Our interactive simulation reflects the complex interdependencies of decision-making between individuals, communities, and the human-made and natural environment. With this interactivity piece we contribute a playful wildfire simulation system.},
booktitle = {Companion Proceedings of the Annual Symposium on Computer-Human Interaction in Play},
pages = {245–252},
numpages = {8},
keywords = {simulation, wildfire, serious game, gameful design, public engagement, awareness},
location = {
},
