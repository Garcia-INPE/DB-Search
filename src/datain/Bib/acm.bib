@article{10.1007/s42979-025-04060-8,
author = {Sneha, N. and Ananda Murthy, Meenakshi Sundaram and Ranjan, Rajeev},
title = {Deep Learning-Based Crop Recommendation Model for Grape and Bean Yield Prediction Using Micro and Macronutrient Analysis},
year = {2025},
issue_date = {Apr 2025},
publisher = {Springer-Verlag},
address = {Berlin, Heidelberg},
volume = {6},
number = {5},
url = {https://doi.org/10.1007/s42979-025-04060-8},
doi = {10.1007/s42979-025-04060-8},
abstract = {Micro- and macro-nutrients in soil play a crucial role in agriculture. Predicting crop yield based on soil characteristics, macro, micro nutrients, temperature, and humidity has been extensively studied using machine learning and deep learning models. The primary objective of the research is to develop a comprehensive model for crop recommendation and yield prediction for three crops—grapes, beans, and chilies—based on macronutrients and micronutrients. The analyzed nutrients include nitrogen, potassium, phosphorus, carbon, sulfur, magnesium, iron, boron, zinc, and calcium, along with natural soil factors such as soil type, pH, humidity, and pesticide presence. The proposed methodology analyzes both tabular and image data for the three crops—grapes, beans, and chilies. The main contribution of this study is the development of two different methods for crop recommendation through yield prediction. The feature selection process is performed using a proposed nsemble model called Random Forest Regressor with Recursive Feature Elimination (RFR-RFE), followed by an Ensemble Deep Neural Network (DNN) model. The RFR-RFE method extracts optimal crop-specific features from the attribute set, which then serve as inputs for a hybrid model called Hybrid Deep Neural Network with Multi-Layer Perceptron (Hybrid DNN-MLP). The proposed Hybrid DNN-MLP model is compared with other machine learning models, including Multiple Linear Regression (MLR) and Random Forest (RF), to evaluate performance. The extracted optimal features for each crop are used to train three models—DNN-MLP, Random Forest, and Regression models—to predict crop yield. The yield predictions are then used to rank crop production. The performance of the machine learning models is assessed using Mean Squared Error (MSE) and R-squared (R2) values, which help in ranking and recommending the most suitable crop for a given area. The proposed Hybrid DNN-MLP model achieved an R2 of 0.98 for grapes, 0.98 for beans, and 0.98 for chilies, outperforming Random Forest (0.97 for grapes and 0.98 for beans) and Multiple Linear Regression (0.91 for grapes and 0.93 for beans). These results demonstrate the effectiveness of the hybrid model in accurately predicting crop yield and optimizing recommendations for agricultural planning.},
journal = {SN Comput. Sci.},
month = jun,
numpages = {18},
keywords = {Artificial neural network, Multi layered perceptron, Agriculture, Regression, Machine learning}
}

