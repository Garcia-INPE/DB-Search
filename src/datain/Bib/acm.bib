@article{10.5555/2772072.2772133,
author = {Eastaugh, C.S. and Hasenauer, H.},
title = {Deriving forest fire ignition risk with biogeochemical process modelling},
year = {2014},
issue_date = {May 2014},
publisher = {Elsevier Science Publishers B. V.},
address = {NLD},
volume = {55},
number = {C},
issn = {1364-8152},
abstract = {Climate impacts the growth of trees and also affects disturbance regimes such as wildfire frequency. The European Alps have warmed considerably over the past half-century, but incomplete records make it difficult to definitively link alpine wildfire to climate change. Complicating this is the influence of forest composition and fuel loading on fire ignition risk, which is not considered by purely meteorological risk indices. Biogeochemical forest growth models track several variables that may be used as proxies for fire ignition risk. This study assesses the usefulness of the ecophysiological model BIOME-BGC's 'soil water' and 'labile litter carbon' variables in predicting fire ignition. A brief application case examines historic fire occurrence trends over pre-defined regions of Austria from 1960 to 2008. Results show that summer fire ignition risk is largely a function of low soil moisture, while winter fire ignitions are linked to the mass of volatile litter and atmospheric dryness. Models developed for forest productivity studies can be used to predict fire ignition risk.Modelled labile carbon levels can be a useful proxy for highly flammable fine fuels.The fire regime in Alpine Europe in summer and winter has different climatic drivers.An increase in summer extreme fire risk days is predicted.},
journal = {Environ. Model. Softw.},
month = may,
pages = {132–142},
numpages = {11},
keywords = {BIOME-BGC, Climate change regions, Fire index, Fire risk, Ignition, Risk indices, Wildfire}
}

@inproceedings{10.5555/2884435.2884544,
author = {Kanade, Varun and Levi, Reut and Lotker, Zvi and Mallmann-Trenn, Frederik and Mathieu, Claire},
title = {Distance in the forest fire model how far are you from eve?},
year = {2016},
isbn = {9781611974331},
publisher = {Society for Industrial and Applied Mathematics},
address = {USA},
abstract = {Leskovec, Kleinberg and Faloutsos (2005) observed that many social networks exhibit properties such as shrinking (i.e. bounded) diameter, densification, and (power-law) heavy tail degree distributions. To explain these phenomena, they introduced a generative model, called the Forest Fire model, and using simulations showed that this model indeed exhibited these properties; however, proving this rigorously was left as an open problem.In this paper, we analyse one of these properties, shrinking diameter. We define a restricted version of their model that incorporates the main features that seem to contribute towards this property, and prove that the graphs generated by this model exhibit shrinking distance to the seed graph. We prove that an even simpler model, the random walk model, already exhibits this phenomenon.},
booktitle = {Proceedings of the Twenty-Seventh Annual ACM-SIAM Symposium on Discrete Algorithms},
pages = {1602–1620},
numpages = {19},
location = {Arlington, Virginia},
series = {SODA '16}
}

@article{10.1016/j.matcom.2007.06.001,
author = {Glasa, Jan and Halada, Ladislav},
title = {On elliptical model for forest fire spread modeling and simulation},
year = {2008},
issue_date = {June, 2008},
publisher = {Elsevier Science Publishers B. V.},
address = {NLD},
volume = {78},
number = {1},
issn = {0378-4754},
url = {https://doi.org/10.1016/j.matcom.2007.06.001},
doi = {10.1016/j.matcom.2007.06.001},
abstract = {A new approach for the derivation of elliptical model of steady-state forest fire spread in time based on classical envelope theory is described. The derivation of this model known in the literature is based on the introduction of a special transform of co-ordinate system which allows to utilize geometrical properties of points lying on common tangent line of two circles. However, the use of this transform means the necessity to apply some specific assumptions onto the model. The proposed new procedure allows us to derive the model without the use of this transform. The new approach enables to better explain the internal coherence of studied problem, assumptions and limitations of the model, as well as to suggest its further generalizations.},
journal = {Math. Comput. Simul.},
month = jun,
pages = {76–88},
numpages = {13},
keywords = {68U35, 81T80, 93A30, Envelope theory, Fire behaviour modeling, Forest fire simulation, Huygens' principle, Local elliptical fire spread}
}

@inproceedings{10.5555/1562334.1562362,
author = {Perminov, Valeriy},
title = {Mathematical modeling of forest fire initiation},
year = {2008},
isbn = {9789604740123},
publisher = {World Scientific and Engineering Academy and Society (WSEAS)},
address = {Stevens Point, Wisconsin, USA},
abstract = {This paper is devoted a problem of development of a mathematical model for description of heat and mass transfer processes at crown forest fire initiation, taking into account the mutual influence of differences strata of forest. Mathematical model of forest fire was based on an analysis of experimental data and using concept and methods from reactive media mechanics. In the context of the general mathematical model of forest fires, this study gives a new three dimensional mathematical setting and method of numerical solution of a problem of a forest fire modeling. The boundary-value problem is solved numerically using the method of splitting according to physical processes. In this paper the assignment and theoretical investigations of the problems of forest fire initiation are carried out. Fields of temperature, velocity, component mass fractions, and volume fractions of phases were obtained numerically.},
