@article{10.1016/j.procs.2015.05.388,
author = {Ghisu, Tiziano and Arca, Bachisio and Pellizzaro, Grazia and Duce, Pierpaolo},
title = {An Improved Cellular Automata for Wildfire Spread},
year = {2015},
issue_date = {September 2015},
publisher = {Elsevier Science Publishers B. V.},
address = {NLD},
volume = {51},
number = {C},
issn = {1877-0509},
url = {https://doi.org/10.1016/j.procs.2015.05.388},
doi = {10.1016/j.procs.2015.05.388},
abstract = {Despite being computationally more efficient than vector-based approaches, the use of raster-based techniques for simulating wildfire spread has been limited by the distortions that affect the fire shapes. This work presents a Cellular Automata approach that is able to mitigate this problem with a redefinition of the spread velocity, where the equations generally used in vector-based approaches are modified by means of a number of correction factors. A numerical optimization approach is used to find the optimal values for the correction factors. The results are compared to the ones given by two well-known Cellular Automata simulators. According to this work, the proposed approach provides better results, at a comparable computational cost.},
journal = {Procedia Comput. Sci.},
month = sep,
pages = {2287–2296},
numpages = {10},
keywords = {Wildfire Spread, Tabu Search, Cellular Automata}
}

@inproceedings{10.5555/3737916.3739769,
author = {Wang, Xinlei and Feng, Maike and Qiu, Jing and Gu, Jinjin and Zhao, Junhua},
title = {From news to forecast: integrating event analysis in LLM-based time series forecasting with reflection},
year = {2025},
isbn = {9798331314385},
publisher = {Curran Associates Inc.},
address = {Red Hook, NY, USA},
abstract = {This paper introduces a novel approach that leverages Large Language Models (LLMs) and Generative Agents to enhance time series forecasting by reasoning across both text and time series data. With language as a medium, our method adaptively integrates social events into forecasting models, aligning news content with time series fluctuations to provide richer insights. Specifically, we utilize LLM-based agents to iteratively filter out irrelevant news and employ human-like reasoning to evaluate predictions. This enables the model to analyze complex events, such as unexpected incidents and shifts in social behavior, and continuously refine the selection logic of news and the robustness of the agent's output. By integrating selected news events with time series data, we fine-tune a pre-trained LLM to predict sequences of digits in time series. The results demonstrate significant improvements in forecasting accuracy, suggesting a potential paradigm shift in time series forecasting through the effective utilization of unstructured news data.},
booktitle = {Proceedings of the 38th International Conference on Neural Information Processing Systems},
articleno = {1853},
numpages = {36},
location = {Vancouver, BC, Canada},
series = {NIPS '24}
}

