doi = {10.1145/3495018.3501056},
abstract = {Aiming at the problem of node location in forest fire monitoring, an improved Low Power Wide Area Network node location algorithm for forest fire monitoring system is proposed this paper. This location algorithm makes full use of the location information of known anchor nodes to modify the location information of unknown nodes without adding other hard nodes in the network. At the same time, the positioning accuracy is further improved. The test results show that the algorithm has better positioning effect than other non-ranging algorithms.},
