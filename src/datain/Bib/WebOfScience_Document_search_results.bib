@inproceedings{ WOS:000089530500047,
Author = {Zimmerman, GT and Bunnell, DL},
Book-Group-Author = {SAF
   SAF},
Title = {Wildland fire management for the 21st century:: Evolving
   applications and capabilities},
Booktitle = {PORTLAND'99: PIONEERING NEW TRAILS, PROCEEDINGS},
Year = {2000},
Pages = {316-323},
Note = {1999 Society-of-American-Foresters National Convention on Pioneering New
   Trails, PORTLAND, OR, SEP 11-15, 1999},
Organization = {Soc Amer Foresters},
Abstract = {During the 20(th) century, fire management has experienced episodic
   shifts in focus and operational management. From its inception early in
   this century, it developed as a strongly directed one-dimensional
   program of fire control. In the early 1970's, with a name change to fire
   management, it expanded into a multi-dimensional program including fire
   control and prescribed fire. During the 1990's, fire management evolved
   at an accelerated rate with greatest advances related to establishment,
   direction, and application of the use of fire for beneficial purposes.
   Two reviews of federal fire policy since 1988 have prompted dramatic
   changes in programmatic function and application. As wildland fire
   management enters the 21(st) century, challenges, risks, program
   complexity, and associated needs will continue to increase. These
   influences will warrant greater application of fire to accomplish
   resource objectives with increased sophistication and effectiveness in
   suppression of unwanted fires. The most significant challenges facing
   this program will be the need to accomplish a wider range of tactical
   applications driven by complex objectives, increased effectiveness in
   operations, sustained cost-efficiency, and divergent but simultaneous
   management operations. Wildland fire management must continue to evolve
   to meet these challenges and will assume more of a one-dimensional
   program appearance to meet multi-faceted dynamic ecological and societal
   needs. Management of wildland fire will wear many different faces and
   will utilize a wider range of options and techniques than ever before to
   concurrently accomplish diverse and complex objectives.},
Publisher = {SOC AMER FORESTERS},
Address = {5400 GROSVENOR LANE, WASHINGTON, DC 20014 USA},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Zimmerman, GT (Corresponding Author), Natl Pk Serv, Fire Sci \& Ecol Program, Natl Interagcy Fire Ctr, Boise, ID USA.
   Natl Pk Serv, Fire Sci \& Ecol Program, Natl Interagcy Fire Ctr, Boise, ID USA.},
Keywords = {wildland fire management; fire policy; appropriate management response},
Research-Areas = {Forestry},
Web-of-Science-Categories  = {Forestry},
Affiliations = {United States Department of the Interior; US National Park Service},
