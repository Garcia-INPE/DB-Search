@article{ WOS:000938755500001,
Author = {Asensio, Maria Isabel and Cascon, Jose Manuel and Prieto-Herraez, Diego
   and Ferragut, Luis},
Title = {An Historical Review of the Simplified Physical Fire Spread Model
   PhyFire: Model and Numerical Methods},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2023},
Volume = {13},
Number = {4},
Month = {FEB},
Abstract = {A historical review is conducted of PhyFire, a simplified physical
   forest fire spread model developed by the research group on Numerical
   Simulation and Scientific Computation (SINUMCC) at the University of
   Salamanca. The review ranges from the first version of the model to the
   current one now integrated into GIS, considering all the mathematical
   problems and numerical methods involved throughout its development:
   finite differences, mixed, classical and adaptive finite elements, data
   assimilation, sensitivity analysis, parameter adjustment, and parallel
   computation, among others. The simulation of processes as complex as
   forest fires involves a multidisciplinary effort that is constantly
   being enhanced, while posing interesting challenges from a mathematical,
   numerical, and computational perspective, without losing sight of the
   overriding aim of developing an efficient, effective, and useful
   simulation tool.},
