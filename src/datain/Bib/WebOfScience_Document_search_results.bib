@article{ WOS:000388492500001,
Author = {Murdoch, Gregory P. and Lindley, T. Todd and Morris, Christopher J.},
Title = {A Doppler Radar and Conceptual Analysis of a Horizontal Longitudinal
   Vortex Influencing the Bastrop Complex Wildfire},
Journal = {JOURNAL OF OPERATIONAL METEOROLOGY},
Year = {2016},
Volume = {4},
Number = {12},
Pages = {160-169},
Month = {AUG 9},
Abstract = {The Bastrop Complex wildfire (BCW) occurred during the record-breaking
   Texas drought of 2011. Although the 139.03 km(-2) (34 356 ac) fire
   burned an area much smaller than the state's largest wildfires, it was
   the largest wildland fire on record in central Texas, and the resultant
   property losses were unprecedented in Texas history. The BCW is of
   meteorological interest because of its simultaneous occurrence and
   interaction with a transient ambient horizontal longitudinal vortex
   (HLV). This study presents a conceptual review of HLVs from the
   perspectives of both meteorology and fire behavior. A thorough Doppler
   radar analysis of the BCW and its interaction with a transient
   pre-existing HLV is provided through observations of the remotely sensed
   debris plume. A basic conceptual model for the phasing of a wildland
   fire's circulation with an ambient HLV is presented, underscoring the
   advantages of using Doppler radar to diagnose near-fire environments for
   tactical firefighting applications.},
