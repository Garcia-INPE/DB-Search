keywords = {Artificial intelligence ;  Canada ;  Climatic changes ;  Cluster analysis ;  Computers ;  Decision making ;  Design ;  Emergency management ;  Environmental aspects ;  Fire prevention ;  Influence ;  Information technology ;  Monte Carlo method ;  Organizational change ;  Remote sensing ;  Satellites ;  Surveys ;  Wildfires},
language = {eng},
