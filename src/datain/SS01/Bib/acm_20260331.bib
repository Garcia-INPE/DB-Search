abstract = {The study of artificial intelligence forces us to understand our own. What is thought - how is human thought different from artificial thought?Graham Morehead is a professor teaching AI at Gonzaga University, and the CEO of Pangeon. For over 25 years, Graham has been developing AI and machine learning solutions to difficult problems. His research led to several TEDx talks and several tech companies. He is currently working to solve problems related to wildfire, real estate, and linguistics.},
journal = {J. Comput. Sci. Coll.},
